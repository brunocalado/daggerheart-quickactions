        </div>
        <span class="dh-qa-tt-value">{{stress.value}}/{{stress.max}}</span>
    </div>

    {{#if partnerName}}
    <div class="dh-qa-tt-row dh-qa-tt-row--meta">
        <span class="dh-qa-tt-label"><i class="fas fa-link"></i> Partner</span>
        <span class="dh-qa-tt-value">{{partnerName}}</span>
    </div>
    {{/if}}

</div>

