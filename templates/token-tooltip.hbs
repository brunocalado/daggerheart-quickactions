{{#if isAdversary}}

<div class="dh-qa-tt-header">
    <span class="dh-qa-tt-name">{{name}}</span>
    <span class="dh-qa-tt-difficulty"><i class="fas fa-skull"></i> {{difficulty}}</span>
</div>

<div class="dh-qa-tt-body">

    <div class="dh-qa-tt-row">
        <span class="dh-qa-tt-label"><i class="fas fa-heart"></i> HP</span>
        <div class="dh-qa-tt-bar-wrap">
            <div class="dh-qa-tt-bar dh-qa-tt-bar--hp" style="--progress: {{hpPct}}%"></div>
        </div>
        <span class="dh-qa-tt-value">{{hp.value}}/{{hp.max}}</span>
    </div>

    <div class="dh-qa-tt-row">
        <span class="dh-qa-tt-label"><i class="fas fa-bolt"></i> Stress</span>
        <div class="dh-qa-tt-bar-wrap">
            <div class="dh-qa-tt-bar dh-qa-tt-bar--stress" style="--progress: {{stressPct}}%"></div>
        </div>
        <span class="dh-qa-tt-value">{{stress.value}}/{{stress.max}}</span>
    </div>

    <div class="dh-qa-tt-divider"></div>

    <div class="dh-qa-tt-thresholds">
        <span class="dh-qa-tt-dt-item">Minor <strong>{{minorDT}}</strong></span>
        <span class="dh-qa-tt-dt-item">Major <strong>{{majorDT}}</strong></span>
        <span class="dh-qa-tt-dt-item">Severe</span>
        {{#if showMassive}}
        <span class="dh-qa-tt-dt-item dh-qa-tt-dt-massive"><strong>{{massiveDT}}</strong> Massive</span>
        {{/if}}
    </div>

    {{#if hasReactions}}
    <div class="dh-qa-tt-divider"></div>
    <div class="dh-qa-tt-features">
        <span class="dh-qa-tt-features-label">Reactions:</span>
        <span class="dh-qa-tt-features-list">{{#each reactions}}{{#if @index}}, {{/if}}{{this}}{{/each}}</span>
    </div>
    {{/if}}

    {{#if hasPassives}}
    <div class="dh-qa-tt-divider"></div>
    <div class="dh-qa-tt-features">
        <span class="dh-qa-tt-features-label">Passive:</span>
        <span class="dh-qa-tt-features-list">{{#each passives}}{{#if @index}}, {{/if}}{{this}}{{/each}}</span>
    </div>
    {{/if}}

</div>

{{else if isCompanion}}

<div class="dh-qa-tt-header">
    <span class="dh-qa-tt-name">{{name}}</span>
    <span class="dh-qa-tt-evasion"><i class="fas fa-person-running"></i> {{evasion}}</span>
</div>

<div class="dh-qa-tt-body">

    <div class="dh-qa-tt-row">
        <span class="dh-qa-tt-label"><i class="fas fa-bolt"></i> Stress</span>
        <div class="dh-qa-tt-bar-wrap">
