<div class="coin-tier-settings">

    <div class="config-card">
        <h3><i class="fas fa-coins"></i> Coin Tier Ranges</h3>

        <div class="form-group">
            <label>Tier 1</label>
            <div class="tier-range">
                <input type="number" name="tier1-min" value="{{tiers.tier1.min}}" min="0" placeholder="Min">
                <span class="range-sep">–</span>
                <input type="number" name="tier1-max" value="{{tiers.tier1.max}}" min="0" placeholder="Max">
                <span class="range-unit">coins</span>
            </div>
        </div>

        <div class="form-group">
            <label>Tier 2</label>
            <div class="tier-range">
                <input type="number" name="tier2-min" value="{{tiers.tier2.min}}" min="0" placeholder="Min">
                <span class="range-sep">–</span>
                <input type="number" name="tier2-max" value="{{tiers.tier2.max}}" min="0" placeholder="Max">
                <span class="range-unit">coins</span>
            </div>
        </div>

        <div class="form-group">
            <label>Tier 3</label>
            <div class="tier-range">
                <input type="number" name="tier3-min" value="{{tiers.tier3.min}}" min="0" placeholder="Min">
                <span class="range-sep">–</span>
                <input type="number" name="tier3-max" value="{{tiers.tier3.max}}" min="0" placeholder="Max">
                <span class="range-unit">coins</span>
            </div>
        </div>

        <div class="form-group">
            <label>Tier 4</label>
            <div class="tier-range">
                <input type="number" name="tier4-min" value="{{tiers.tier4.min}}" min="0" placeholder="Min">
                <span class="range-sep">–</span>
                <input type="number" name="tier4-max" value="{{tiers.tier4.max}}" min="0" placeholder="Max">
                <span class="range-unit">coins</span>
            </div>
        </div>

        <button type="button" class="reset-btn">
            <i class="fas fa-undo"></i> Reset to Defaults
        </button>
    </div>

    <footer class="sheet-footer flexrow">
        <button type="submit" name="submit">
            <i class="far fa-save"></i> Save Configuration
        </button>
    </footer>

</div>
