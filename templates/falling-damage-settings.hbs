<div class="falling-damage-settings">

    <div class="config-card">
        <h3><i class="fas fa-skull-crossbones"></i> Falling Damage Formulas</h3>

        <div class="form-group">
            <label>Very Close Range</label>
            <input type="text" name="veryclose" value="{{formulas.veryclose}}" placeholder="e.g., 1d10+3" maxlength="20">
            <span class="hint">Damage formula for very close fall distances.</span>
        </div>

        <div class="form-group">
            <label>Close Range</label>
            <input type="text" name="close" value="{{formulas.close}}" placeholder="e.g., 1d20+5" maxlength="20">
            <span class="hint">Damage formula for close fall distances.</span>
        </div>

        <div class="form-group">
            <label>Far / Very Far Range</label>
            <input type="text" name="far" value="{{formulas.far}}" placeholder="e.g., 1d100+15" maxlength="20">
            <span class="hint">Damage formula for far and very far fall distances.</span>
        </div>

        <div class="form-group">
            <label>Collision</label>
            <input type="text" name="collision" value="{{formulas.collision}}" placeholder="e.g., 1d20+5" maxlength="20">
            <span class="hint">Damage formula for collision damage.</span>
        </div>

        <button type="button" class="reset-btn">
            <i class="fas fa-undo"></i> Reset to Defaults
        </button>
    </div>

    <footer class="sheet-footer flexrow">
        <button type="submit" name="submit">
            <i class="far fa-save"></i> Save Configuration
        </button>
    </footer>

</div>
